rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Attempts Collection
    match /attempts/{attemptId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }

    // Flashcards Collection
    match /flashcards/{deckId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }

    // StudyPlans Collection
    match /studyPlans/{planId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}